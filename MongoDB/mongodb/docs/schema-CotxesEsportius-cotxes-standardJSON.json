{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "_id",
    "dataAlta",
    "descripcio",
    "disponible",
    "marca",
    "model",
    "potenciaCV",
    "preu"
  ],
  "properties": {
    "_id": {
      "$ref": "#/$defs/ObjectId"
    },
    "dataAlta": {
      "$ref": "#/$defs/Date"
    },
    "descripcio": {
      "type": "string"
    },
    "disponible": {
      "type": "boolean"
    },
    "marca": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "potenciaCV": {
      "type": "integer"
    },
    "preu": {
      "type": "integer"
    }
  },
  "$defs": {
    "ObjectId": {
      "type": "object",
      "properties": {
        "$oid": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{24}$"
        }
      },
      "required": [
        "$oid"
      ],
      "additionalProperties": false
    },
    "Date": {
      "type": "object",
      "properties": {
        "$date": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "$date"
      ],
      "additionalProperties": false
    }
  }
}